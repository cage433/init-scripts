[receive]
	denyNonFastForwards = true

[merge]
  conflictstyle = diff3
	stat = true

[diff]
  colorMoved = default
	conflictstyle = diff3
	renames = copies
	mnemonicprefix = true
  tool=vimdiff
  renameLimit=5000

[interactive]
  diffFilter = delta --color-only

[branch]
	autosetupmerge = true
	autosetuprebase = always

[push]
	default = current

[alias]
	s = status
  sh = show --pretty=format:
	a = add
	b = branch
	l = log --graph --pretty=format:'%C(yellow)%h%C(cyan)%d%Creset %s %C(white)- %an, %ar%Creset'
  ll = log --pretty=format:"%C(yellow)%h%Cred%d\\ %Creset%s%Cblue\\ [%cn]" --decorate --numstat
	d = diff --color-words

[pull]
	default = current
	rebase = true
	ff = only

[color]
	ui = auto

[difftool]
	prompt = false

[user]
	email = cage433@gmail.com
	name = cage433

