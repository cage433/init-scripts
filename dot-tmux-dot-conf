# act like vim
set-option -g display-time 120




setw -g mode-keys vi
set -g base-index 1
#bind C-l send-keys 'C-l'


# act like GNU screen
unbind C-b
set -g prefix C-a

# Don't prompt before killng pane
unbind x
bind x kill-pane 

# Move to beginning of line
bind a send-prefix

set -g status on
bind-key b set-option status

unbind r
bind r source-file ~/.tmux.conf


set -g display-time 2000
set -g renumber-windows on
#set -g @plugin 'christoomey/vim-tmux-navigator'
#set -g @plugin 'tmux-plugins/tmux-sensible'

bind h select-pane -L
bind j select-pane -D
bind k select-pane -U
bind l select-pane -R
run '~/.tmux/plugins/tpm/tpm'

# New sessions open in the same directory as the current pane
bind c new-window -c "#{pane_current_path}"

# Pane splits should open to the same path as the current pane
bind '"' split-window -v -c "#{pane_current_path}"
bind % split-window -h -c "#{pane_current_path}"

unbind t
bind t send-keys -t 1 "C-l" "dune test" Enter

unbind t
bind t send-keys -t 1 "C-l" "pdflatex split-fx.tex" Enter
