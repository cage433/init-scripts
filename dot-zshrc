# Lazily load pyenv to prevent slowing down new shells
# Create an autoload directory
mkdir -p "$HOME/.zsh/autoloads"
fpath=("$HOME/.zsh/autoloads" $fpath)

# Define a function to initialize pyenv
pyenv_init() {
  export PYENV_ROOT="$HOME/.pyenv"
  command -v pyenv >/dev/null || export PATH="$PYENV_ROOT/bin:$PATH"
  eval "$(pyenv init -)" > /dev/null
  eval "$(pyenv virtualenv-init -)" > /dev/null # If you use pyenv-virtualenv
}

